    "help": [
        {
            "name": "ARGV",
            "msg": "argv\t(Execute command line parameters)",
            "usage": {
                "[current instance] [command]": "Console runs the current executable file with parameters passed in, executes a single command but does not start interactive mode",
                "[current instance] -r \"[command1];[command2];...\"": "The console runs the current executable file with the parameter - r, sequentially traverses and executes the incoming commands, executes multiple commands without starting interactive mode"
            }
        },
        {
            "name": "CD",
            "msg": "cd\t(change directory)",
            "usage": {
                "cd [directory path]": "Change to the specified directory",
                "cd ../": "Change to the parent directory",
                "cd /": "Change to root directory",
                "cd drive:": "Switch to specified drive (Windows only)"
            }
        },
        {
            "name": "CLEAR",
            "msg": "clear\t(clear screen)",
            "usage": {
                "clear": "Clear the screen directly"
            }
        },
        {
            "name": "EXIT",
            "msg": "exit\t(exit program)",
            "usage": {
                "exit": "Exit the program directly",
                "exit -f": "Force exit the program"
            }
        },
        {
            "name": "HELP",
            "msg": "help\t(print help information)",
            "usage": {
                "help": "Show detailed information about all commands",
                "help [command]": "Show detailed information about specific command"
            }
        },
        {
            "name": "LS",
            "msg": "ls\t(list directory contents)",
            "usage": {
                "ls": "List files in current directory",
                "ls -l": "List files in detail",
                "ls -a": "Include hidden (dot) files",
                "ls -1": "One entry per line",
                "ls --sort name|time|size": "Sort by name/time/size (default: name)",
                "ls -r": "Reverse sort",
                "ls --no-color": "Disable ANSI colors",
                "ls [path]": "List a specific directory"
            }
        },
        {
            "name": "LL",
            "msg": "ll\t(list directory contents)",
            "usage": {
                "ll": "List files in detail (same as ls -l)",
                "ll -a": "Include hidden (dot) files",
                "ll --no-color": "Disable ANSI colors",
                "ll [path]": "List a specific directory"
            }
        },
        {
            "name": "PWD",
            "msg": "pwd\t(print working directory)",
            "usage": {
                "pwd": "Show current directory path"
            }
        },
        {
            "name": "VERSION",
            "msg": "version\t(show version information)",
            "usage": {
                "version": "Display version number and release date"
            }
        },
        {
            "name": "VIDEO",
            "msg": "video\t(play video in console)",
            "usage": {
                "video test": "Test video playback",
                "video [video path]": "Play specified video (fit to terminal)",
                "video [video path] -w 120": "Limit render width (columns)",
                "video [video path] -h 30": "Limit render height (rows)",
                "video [video path] --fps 15": "Override playback FPS (lower can reduce lag)",
                "video [video path] --loop": "Loop playback",
                "video [video path] --gray": "Grayscale render (still uses color blocks)",
                "video [video path] --no-color": "ASCII render without colors (better compatibility)"
            }
        },
        {
            "name": "IMG",
            "msg": "img\t(view image in console)",
            "usage": {
                "img test": "Render the built-in test image",
                "img [image path]": "Render an image in low resolution (fit to terminal)",
                "img [image path] -w 120": "Limit render width (columns)",
                "img [image path] -h 30": "Limit render height (rows)",
                "img [image path] --gray": "Grayscale render (still uses color blocks)",
                "img [image path] --no-color": "ASCII render without colors (better compatibility)"
            }
        },
        {
            "name": "PCK",
            "msg": "pck\t(package manager)",
            "usage": {
                "pck install [pkg1] [pkg2] ...": "Install one or more packages",
                "pck install [pkg...] -y": "Install without confirmation",
                "pck update": "Update package index/list",
                "pck list": "List installed packages",
                "pck search [keyword]": "Search packages"
            }
        },
        {
            "name": "DOWNLOAD",
            "msg": "download\t(download file)",
            "usage": {
                "download [URL] [save path]": "Download a file to the specified path"
            }
        },
        {
            "name": "RM",
            "msg": "rm\t(remove files/directories)",
            "usage": {
                "rm [file...]": "Remove one or more files (asks for confirmation)",
                "rm -f [file...]": "Force remove (no confirmation)",
                "rm -r [dir...]": "Recursive remove directories (asks for confirmation)",
                "rm -rf [dir/file...]": "Recursive force remove"
            }
        },
        {
            "name": "SET",
            "msg": "set\t(update Config)",
            "usage": {
                "set [key] [value]": "Update Config in config.json (dot path supported, e.g. Pck.Name)",
                "set Lang en-US": "Switch language",
                "set Pck.Addr http://127.0.0.1:8081/": "Set pck server address"
            }
        },
        {
            "name": "PATH",
            "msg": "path\t(manage PATH)",
            "usage": {
                "path": "Show current PATH (merged temp + persistent)",
                "path list": "List persistent/temp PATH entries",
                "path add [dir]": "Add to persistent PATH (default)",
                "path add [dir] -p": "Add to persistent PATH (writes path.json)",
                "path add [dir] -t": "Add to temporary PATH (session only)",
                "path rm [dir]": "Remove from persistent PATH (default)",
                "path rm [dir] -t": "Remove from temporary PATH",
                "path rm [dir] --all": "Remove from both persistent and temporary",
                "path clear -p": "Clear persistent PATH",
                "path clear -t": "Clear temporary PATH",
                "path clear --all": "Clear both persistent and temporary"
            }
        },
        {
            "name": "ENV",
            "msg": "env\t(read environment variables)",
            "usage": {
                "env": "Print PATH (merged temp + persistent)",
                "env PATH": "Print PATH (same as above)",
                "env [VAR]": "Print an environment variable (from process env)"
            }
        }
    ]
}